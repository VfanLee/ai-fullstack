{
  "name": "@ai-fullstack/shared",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup --clean",
    "clean": "node -e \"fs.rmSync('dist', { recursive: true, force: true })\"",
    "dev": "tsup --watch",
    "lint": "eslint src --ext .ts"
  },
  "devDependencies": {
    "tsup": "^8.5.0"
  }
}
